# ─── Commands ──────────────────────────────────────────────────────────────────

cmd_init() {
  local FOUNDRY_UPDATE_TOKEN="${FOUNDRY_UPDATE_TOKEN:-false}"

  while [ $# -gt 0 ]; do
    case "$1" in
      --token)
        FOUNDRY_TOKEN_INPUT="${2:-}"
        shift 2
        ;;
      --update-token)
        FOUNDRY_UPDATE_TOKEN="true"
        shift
        ;;
      --help|-h)
        echo "Usage: foundry init [--token TOKEN] [--update-token]"
        echo ""
        echo "  --token TOKEN       Set or replace the service token for this folder"
        echo "  --update-token      Prompt to replace the saved token in this folder"
        exit 0
        ;;
      *)
        error "Unknown option: $1"
        echo "Usage: foundry init [--token TOKEN] [--update-token]"
        exit 1
        ;;
    esac
  done

  print_project_banner

  if is_existing_setup; then
    warn "This folder already has Foundry configuration."
    info "Re-running init will update files in ${DIM}$(pwd)${RESET} only."
    echo ""
    if ! prompt_yes_no "Continue?" "y"; then
      info "Cancelled."
      exit 0
    fi
    echo ""
  fi

  collect_token
  collect_mcp_url
  collect_app_slug

  echo ""
  detect_agents
  local agent_list
  agent_list=$(printf '%s, ' "${AGENTS[@]}")
  info "Detected agents: ${agent_list%, }"
  echo ""

  save_config

  # ── .gitignore guard ─────────────────────────────────────────────────────
  if [ -f ".gitignore" ]; then
    if ! grep -qxF '.foundry/' .gitignore 2>/dev/null; then
      echo '.foundry/' >> .gitignore
      success "Added ${DIM}.foundry/${RESET} to .gitignore"
    fi
  else
    echo '.foundry/' > .gitignore
    success "Created .gitignore with ${DIM}.foundry/${RESET}"
  fi

  # ── Claude Code setup ───────────────────────────────────────────────────
  header "Claude Code"

  local claude_mcp
  claude_mcp=$(cat <<JSON
{
  "mcpServers": {
    "assembly-foundry": {
      "type": "streamable-http",
      "url": "\${ASSEMBLY_MCP_URL:-$FOUNDRY_MCP_URL}",
      "headers": {
        "Authorization": "Bearer \${ASSEMBLY_FOUNDRY_TOKEN}"
      }
    }
  }
}
JSON
)
  write_file ".mcp.json" "$claude_mcp"
  success "Created: ${DIM}.mcp.json${RESET}"

  ensure_dir ".claude/skills/foundry"
  write_file ".claude/skills/foundry/SKILL.md" "$SKILL_CONTENT"
  success "Created: ${DIM}.claude/skills/foundry/SKILL.md${RESET}"

  # ── Cursor setup ─────────────────────────────────────────────────────────
  header "Cursor"

  local cursor_mcp
  cursor_mcp=$(cat <<JSON
{
  "mcpServers": {
    "assembly-foundry": {
      "url": "$FOUNDRY_MCP_URL",
      "headers": {
        "Authorization": "Bearer \${ASSEMBLY_FOUNDRY_TOKEN}"
      }
    }
  }
}
JSON
)
  ensure_dir ".cursor"
  write_file ".cursor/mcp.json" "$cursor_mcp"
  success "Created: ${DIM}.cursor/mcp.json${RESET}"

  ensure_dir ".cursor/rules"
  write_file ".cursor/rules/foundry-agent.mdc" "$CURSOR_RULE_CONTENT"
  success "Created: ${DIM}.cursor/rules/foundry-agent.mdc${RESET}"

  # ── Env var hint ─────────────────────────────────────────────────────────
  header "Start coding from this folder"
  echo ""
  echo -e "Foundry config is ${BOLD}folder-specific${RESET}. Launch agents from:"
  echo -e "  ${BLUE}$(pwd)${RESET}"
  echo ""
  echo -e "Load this project's token before starting an agent:"
  echo ""
  echo -e "  ${BOLD}source .foundry/env && claude${RESET}"
  echo -e "  ${BOLD}source .foundry/env && cursor .${RESET}"
  echo ""
  echo -e "Or export manually for this shell:"
  echo ""
  echo -e "  ${BOLD}export ASSEMBLY_FOUNDRY_TOKEN=\"$(mask_token "$FOUNDRY_TOKEN")\"${RESET}"
  echo -e "  ${DIM}# full token saved in .foundry/env${RESET}"

  if [ -n "${FOUNDRY_APP_SLUG:-}" ]; then
    echo ""
    echo -e "Suggested first prompt:"
    echo ""
    echo -e "  ${DIM}claude${RESET}"
    echo -e "  ${BOLD}> Pull the Foundry context for \"$FOUNDRY_APP_SLUG\" and start building.${RESET}"
  fi

  echo ""
  echo -e "${DIM}To change the token later in this folder:${RESET}"
  echo -e "  ${BOLD}foundry init --update-token${RESET}"
  echo -e "  ${BOLD}foundry init --token sat_new...${RESET}"
  echo ""
  success "Foundry init complete for ${DIM}$(pwd)${RESET}."
}

cmd_status() {
  header "Foundry Status"
  echo -e "${BOLD}Project directory:${RESET} ${BLUE}$(pwd)${RESET}"
  echo -e "${DIM}Foundry config is folder-specific. Run status in each project to inspect that folder.${RESET}"
  echo ""
  load_config

  local ok=true

  if [ -f ".mcp.json" ]; then
    success ".mcp.json exists"
  else
    warn ".mcp.json missing — run ${BOLD}foundry init${RESET} in this folder"
    ok=false
  fi

  if [ -f ".claude/skills/foundry/SKILL.md" ]; then
    success ".claude/skills/foundry/SKILL.md exists"
  else
    warn ".claude/skills/foundry/SKILL.md missing"
    ok=false
  fi

  if [ -f ".cursor/mcp.json" ]; then
    success ".cursor/mcp.json exists"
  else
    warn ".cursor/mcp.json missing"
    ok=false
  fi

  if [ -f ".cursor/rules/foundry-agent.mdc" ]; then
    success ".cursor/rules/foundry-agent.mdc exists"
  else
    warn ".cursor/rules/foundry-agent.mdc missing"
    ok=false
  fi

  if [ -f "$FOUNDRY_CONFIG_FILE" ]; then
    success "Folder config exists (${DIM}$FOUNDRY_CONFIG_FILE${RESET})"
    if [ -n "${FOUNDRY_TOKEN:-}" ]; then
      info "Saved token: $(mask_token "$FOUNDRY_TOKEN")"
    fi
    if [ -n "${FOUNDRY_APP_SLUG:-}" ]; then
      info "App slug: ${FOUNDRY_APP_SLUG}"
    fi
  else
    warn "No folder config — run ${BOLD}foundry init${RESET} in this directory"
    ok=false
  fi

  if [ -f "$FOUNDRY_ENV_FILE" ]; then
    success "Folder env file exists (${DIM}$FOUNDRY_ENV_FILE${RESET})"
  else
    warn "Folder env file missing"
    ok=false
  fi

  if [ -n "${ASSEMBLY_FOUNDRY_TOKEN:-}" ]; then
    success "Current shell has ASSEMBLY_FOUNDRY_TOKEN set ($(mask_token "$ASSEMBLY_FOUNDRY_TOKEN"))"
  else
    warn "Current shell has no ASSEMBLY_FOUNDRY_TOKEN — run ${BOLD}source .foundry/env${RESET} in this folder"
    ok=false
  fi

  local mcp_url="${FOUNDRY_MCP_URL:-${ASSEMBLY_MCP_URL:-http://localhost:8082/v0/mcp-tools/stream}}"
  if curl -sf --max-time 3 "$mcp_url" >/dev/null 2>&1 || curl -sf --max-time 3 -o /dev/null -w '%{http_code}' "$mcp_url" 2>/dev/null | grep -q '[2-4]'; then
    success "MCP server reachable at ${DIM}$mcp_url${RESET}"
  else
    warn "MCP server not reachable at ${DIM}$mcp_url${RESET}"
    ok=false
  fi

  echo ""
  if [ "$ok" = true ]; then
    success "All checks passed. Ready to use Foundry."
  else
    warn "Some checks failed. Run ${BOLD}foundry init${RESET} to fix."
  fi
}

cmd_version() {
  echo "foundry $FOUNDRY_VERSION"
}

cmd_help() {
  echo -e "${BOLD}foundry${RESET} — CLI for Assembly Foundry agent integration"
  echo ""
  echo -e "${BOLD}USAGE${RESET}"
  echo "  foundry <command> [options]"
  echo ""
  echo -e "${BOLD}COMMANDS${RESET}"
  echo "  init      Set up Foundry in the current project folder"
  echo "  status    Check Foundry setup for the current folder"
  echo "  version   Print version"
  echo "  help      Show this help"
  echo ""
  echo -e "${BOLD}INIT OPTIONS${RESET}"
  echo "  --token TOKEN       Set or replace the service token for this folder"
  echo "  --update-token      Prompt to replace the saved token in this folder"
  echo ""
  echo -e "${BOLD}EXAMPLES${RESET}"
  echo "  cd my-project && foundry init"
  echo "  FOUNDRY_TOKEN=sat_xxx foundry init"
  echo "  foundry init --token sat_new..."
  echo "  foundry init --update-token"
  echo "  source .foundry/env && claude"
  echo "  foundry status"
  echo ""
  echo -e "${BOLD}ENVIRONMENT${RESET}"
  echo "  FOUNDRY_TOKEN       Service token for this folder (non-interactive init)"
  echo "  FOUNDRY_MCP_URL     MCP server URL (default: http://localhost:8082/v0/mcp-tools/stream)"
  echo "  FOUNDRY_APP_SLUG    Default app slug for this folder"
}

# ─── Entrypoint ────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)    cmd_init "$@" ;;
    status)  cmd_status "$@" ;;
    version) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)
      error "Unknown command: $cmd"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
