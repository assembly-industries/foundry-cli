#!/usr/bin/env bash
set -euo pipefail

FOUNDRY_VERSION="0.1.0"
FOUNDRY_CONFIG_DIR=".foundry"
FOUNDRY_CONFIG_FILE="$FOUNDRY_CONFIG_DIR/config"

# ─── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

info()    { echo -e "${BLUE}▸${RESET} $*"; }
success() { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*"; }
error()   { echo -e "${RED}✖${RESET} $*" >&2; }
header()  { echo -e "\n${BOLD}$*${RESET}"; }

# ─── Helpers ───────────────────────────────────────────────────────────────────
ensure_dir() { mkdir -p "$1"; }

write_file() {
  local path="$1" content="$2"
  ensure_dir "$(dirname "$path")"
  echo "$content" > "$path"
}

write_file_if_missing() {
  local path="$1" content="$2"
  if [ -f "$path" ]; then
    warn "Already exists, skipping: ${DIM}$path${RESET}"
    return
  fi
  write_file "$path" "$content"
  success "Created: ${DIM}$path${RESET}"
}

save_config() {
  ensure_dir "$FOUNDRY_CONFIG_DIR"
  cat > "$FOUNDRY_CONFIG_FILE" <<CFG
# Foundry CLI config — generated by foundry init
FOUNDRY_TOKEN="$FOUNDRY_TOKEN"
FOUNDRY_MCP_URL="$FOUNDRY_MCP_URL"
FOUNDRY_APP_SLUG="$FOUNDRY_APP_SLUG"
CFG
  success "Config saved: ${DIM}$FOUNDRY_CONFIG_FILE${RESET}"
}

load_config() {
  if [ -f "$FOUNDRY_CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    source "$FOUNDRY_CONFIG_FILE"
  fi
}

detect_agents() {
  AGENTS=()
  if command -v claude &>/dev/null; then
    AGENTS+=("claude-code")
  fi
  if [ -d ".cursor" ] || command -v cursor &>/dev/null; then
    AGENTS+=("cursor")
  fi
  if [ ${#AGENTS[@]} -eq 0 ]; then
    AGENTS=("claude-code" "cursor")
  fi
}

# ─── SKILL.md content ─────────────────────────────────────────────────────────
SKILL_CONTENT='---
name: foundry
description: "Read product specs (apps, PRDs, features) from Assembly Foundry and write back implementation progress. Use when the user mentions PRD, product spec, foundry, features to build, or building from a spec."
allowed-tools: mcp__assembly-foundry__foundry_get_context mcp__assembly-foundry__foundry_get_prd mcp__assembly-foundry__foundry_list_features mcp__assembly-foundry__foundry_update_feature mcp__assembly-foundry__foundry_add_feature mcp__assembly-foundry__foundry_get_architecture mcp__assembly-foundry__foundry_update_architecture mcp__assembly-foundry__foundry_record_session
---

# Assembly Foundry — Coding Agent Integration

You have access to Assembly Foundry via MCP tools. Foundry holds the product specification (apps, PRDs, features, domain models) that you should code against.

## Available tools

| Tool | When to use |
|------|-------------|
| `foundry_get_context` | **Start here.** Fetches an app + all linked PRDs in one call. Pass the app slug. |
| `foundry_get_prd` | Get a single PRD by id when you need the full document markdown. |
| `foundry_list_features` | List features for a PRD to check status or find feature ids. |
| `foundry_update_feature` | After implementing a feature, update its status and add technical notes. |
| `foundry_add_feature` | When you discover a new capability not in the PRD, add it. |
| `foundry_get_architecture` | Get the system architecture for a PRD. |
| `foundry_update_architecture` | Update system architecture — components, integrations, Mermaid diagram, notes. |
| `foundry_record_session` | At the end of significant work, log a session summary with git info. |

## Workflow

1. **Pull context** — call `foundry_get_context` with the app slug before coding.
2. **Build features** — reference PRD features and acceptance criteria.
3. **Report progress** — call `foundry_update_feature` after implementing a feature.
4. **Add new features** — call `foundry_add_feature` for capabilities not in the PRD.
5. **Document architecture** — call `foundry_update_architecture` after adding services, databases, integrations.
6. **Log sessions** — call `foundry_record_session` at the end of significant work.

## Notes

- Always use `foundry_get_context` before starting work.
- Feature status updates are visible in the admin UI.
- The `agent_source` should be `"claude-code"` or `"cursor"` depending on platform.
- Idempotency keys prevent duplicate events on retry.'

