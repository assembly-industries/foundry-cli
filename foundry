#!/usr/bin/env bash
set -euo pipefail

FOUNDRY_VERSION="0.1.0"
FOUNDRY_CONFIG_DIR=".foundry"
FOUNDRY_CONFIG_FILE="$FOUNDRY_CONFIG_DIR/config"
FOUNDRY_ENV_FILE="$FOUNDRY_CONFIG_DIR/env"

# ─── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

info()    { echo -e "${BLUE}▸${RESET} $*"; }
success() { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET} $*"; }
error()   { echo -e "${RED}✖${RESET} $*" >&2; }
header()  { echo -e "\n${BOLD}$*${RESET}"; }

# ─── Helpers ───────────────────────────────────────────────────────────────────
ensure_dir() { mkdir -p "$1"; }

write_file() {
  local path="$1" content="$2"
  ensure_dir "$(dirname "$path")"
  echo "$content" > "$path"
}

write_file_if_missing() {
  local path="$1" content="$2"
  if [ -f "$path" ]; then
    warn "Already exists, skipping: ${DIM}$path${RESET}"
    return
  fi
  write_file "$path" "$content"
  success "Created: ${DIM}$path${RESET}"
}

save_config() {
  FOUNDRY_TOKEN="${FOUNDRY_TOKEN:-}"
  FOUNDRY_MCP_URL="${FOUNDRY_MCP_URL:-}"
  FOUNDRY_APP_SLUG="${FOUNDRY_APP_SLUG:-}"

  ensure_dir "$FOUNDRY_CONFIG_DIR"
  cat > "$FOUNDRY_CONFIG_FILE" <<CFG
# Foundry CLI config — folder-specific, generated by foundry init
# Project: $(pwd)
FOUNDRY_TOKEN="$FOUNDRY_TOKEN"
FOUNDRY_MCP_URL="$FOUNDRY_MCP_URL"
FOUNDRY_APP_SLUG="$FOUNDRY_APP_SLUG"
CFG

  cat > "$FOUNDRY_ENV_FILE" <<ENV
# Foundry folder-local environment
# Source before launching an agent from THIS project directory:
#   source .foundry/env && claude
#   source .foundry/env && cursor .
export ASSEMBLY_FOUNDRY_TOKEN="$FOUNDRY_TOKEN"
export ASSEMBLY_MCP_URL="$FOUNDRY_MCP_URL"
ENV

  success "Saved folder config: ${DIM}$FOUNDRY_CONFIG_FILE${RESET}"
  success "Saved folder env: ${DIM}$FOUNDRY_ENV_FILE${RESET}"
}

load_config() {
  if [ -f "$FOUNDRY_CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    source "$FOUNDRY_CONFIG_FILE"
  fi
}

mask_token() {
  local token="$1"
  if [ -z "$token" ]; then
    echo "(not set)"
    return
  fi
  if [ "${#token}" -le 8 ]; then
    echo "****"
    return
  fi
  echo "${token:0:4}...${token: -4}"
}

is_existing_setup() {
  [ -f "$FOUNDRY_CONFIG_FILE" ] || [ -f ".mcp.json" ] || [ -f ".cursor/mcp.json" ]
}

prompt_yes_no() {
  local prompt="$1" default="${2:-y}"
  local reply=""
  if [ "$default" = "y" ]; then
    echo -en "${BOLD}$prompt${RESET} ${DIM}[Y/n]${RESET}: "
  else
    echo -en "${BOLD}$prompt${RESET} ${DIM}[y/N]${RESET}: "
  fi
  read -r reply
  reply=$(echo "$reply" | tr '[:upper:]' '[:lower:]')
  if [ -z "$reply" ]; then
    reply="$default"
  fi
  [ "$reply" = "y" ] || [ "$reply" = "yes" ]
}

print_project_banner() {
  local project_dir
  project_dir="$(pwd)"
  header "Foundry Init"
  echo -e "${DIM}Project-specific setup — like Claude Code, everything installs into the folder you run this from.${RESET}"
  echo ""
  echo -e "${BOLD}Project directory:${RESET}"
  echo -e "  ${BLUE}$project_dir${RESET}"
  echo ""
  echo -e "${BOLD}Files that will be created or updated here:${RESET}"
  echo -e "  ${DIM}.mcp.json${RESET}                         Claude Code MCP config"
  echo -e "  ${DIM}.claude/skills/foundry/SKILL.md${RESET}   Claude Code skill"
  echo -e "  ${DIM}.cursor/mcp.json${RESET}                  Cursor MCP config"
  echo -e "  ${DIM}.cursor/rules/foundry-agent.mdc${RESET}   Cursor rule"
  echo -e "  ${DIM}.foundry/config${RESET}                   Local token + settings (gitignored)"
  echo -e "  ${DIM}.foundry/env${RESET}                      Folder-local env exports (gitignored)"
  echo ""
  echo -e "${DIM}Run foundry init separately in each coding project. Config does not leak across folders.${RESET}"
  echo ""
}

collect_token() {
  local env_token="${FOUNDRY_TOKEN:-}"
  local update_token="${FOUNDRY_UPDATE_TOKEN:-false}"
  local saved_token=""

  if [ -n "${FOUNDRY_TOKEN_INPUT:-}" ]; then
    FOUNDRY_TOKEN="$FOUNDRY_TOKEN_INPUT"
    info "Using token from ${DIM}--token${RESET}"
    return
  fi

  load_config
  if [ -f "$FOUNDRY_CONFIG_FILE" ]; then
    saved_token="${FOUNDRY_TOKEN:-}"
  else
    saved_token=""
  fi
  FOUNDRY_TOKEN="$env_token"

  if [ -n "$env_token" ] && [ "$update_token" != "true" ] && [ -z "$saved_token" ]; then
    FOUNDRY_TOKEN="$env_token"
    info "Using token from environment: ${DIM}FOUNDRY_TOKEN${RESET}"
    return
  fi

  if [ -n "$env_token" ] && [ "$update_token" != "true" ] && [ -n "$saved_token" ] && [ "$env_token" != "$saved_token" ]; then
    FOUNDRY_TOKEN="$env_token"
    info "Replacing saved token with ${DIM}FOUNDRY_TOKEN${RESET} from environment"
    return
  fi

  if [ -n "$saved_token" ] && [ "$update_token" != "true" ] && [ -z "$env_token" ]; then
    info "Saved token in this folder: $(mask_token "$saved_token")"
    if prompt_yes_no "Keep this service token?" "y"; then
      FOUNDRY_TOKEN="$saved_token"
      return
    fi
  fi

  if [ -n "$saved_token" ]; then
    info "Current token: $(mask_token "$saved_token")"
  fi

  echo -en "${BOLD}Foundry service token${RESET} ${DIM}[paste new token, Enter to cancel]${RESET}: "
  read -r FOUNDRY_TOKEN
  if [ -z "$FOUNDRY_TOKEN" ]; then
    if [ -n "$saved_token" ]; then
      FOUNDRY_TOKEN="$saved_token"
      info "Keeping existing token"
      return
    fi
    error "Token is required. Generate one from the admin UI → Agent Access tab."
    exit 1
  fi
}

collect_mcp_url() {
  local env_url="${FOUNDRY_MCP_URL:-}"
  local default_url="http://localhost:8082/v0/mcp-tools/stream"
  local saved_url=""
  local current_token="${FOUNDRY_TOKEN:-}"

  load_config
  if [ -f "$FOUNDRY_CONFIG_FILE" ]; then
    saved_url="${FOUNDRY_MCP_URL:-}"
  else
    saved_url=""
  fi
  FOUNDRY_MCP_URL="$env_url"
  FOUNDRY_TOKEN="$current_token"

  if [ -n "$env_url" ] && [ "${FOUNDRY_UPDATE_TOKEN:-false}" != "true" ]; then
    FOUNDRY_MCP_URL="$env_url"
    info "Using MCP URL from environment: ${DIM}FOUNDRY_MCP_URL${RESET}"
    return
  fi

  if [ -n "$saved_url" ] && { [ -n "${FOUNDRY_TOKEN_INPUT:-}" ] || [ "${FOUNDRY_UPDATE_TOKEN:-false}" = "true" ]; }; then
    FOUNDRY_MCP_URL="$saved_url"
    info "Using saved MCP URL: ${DIM}$saved_url${RESET}"
    return
  fi

  if [ -n "$saved_url" ]; then
    default_url="$saved_url"
  fi

  echo -en "${BOLD}MCP server URL${RESET} ${DIM}[$default_url]${RESET}: "
  read -r input_url
  FOUNDRY_MCP_URL="${input_url:-$default_url}"
}

collect_app_slug() {
  local env_slug="${FOUNDRY_APP_SLUG:-}"
  local saved_slug=""
  local current_token="${FOUNDRY_TOKEN:-}"

  if [ -n "$env_slug" ]; then
    FOUNDRY_APP_SLUG="$env_slug"
    info "Using app slug from environment: ${DIM}FOUNDRY_APP_SLUG${RESET}"
    return
  fi

  load_config
  if [ -f "$FOUNDRY_CONFIG_FILE" ]; then
    saved_slug="${FOUNDRY_APP_SLUG:-}"
  fi
  FOUNDRY_APP_SLUG="$env_slug"
  FOUNDRY_TOKEN="$current_token"

  if [ -n "$saved_slug" ] && { [ -n "${FOUNDRY_TOKEN_INPUT:-}" ] || [ "${FOUNDRY_UPDATE_TOKEN:-false}" = "true" ]; }; then
    FOUNDRY_APP_SLUG="$saved_slug"
    info "Using saved app slug: ${DIM}$saved_slug${RESET}"
    return
  fi

  if [ -z "$saved_slug" ] && { [ -n "${FOUNDRY_TOKEN_INPUT:-}" ] || [ "${FOUNDRY_UPDATE_TOKEN:-false}" = "true" ]; }; then
    FOUNDRY_APP_SLUG=""
    return
  fi

  if [ -n "$saved_slug" ]; then
    echo -en "${BOLD}Foundry app slug${RESET} ${DIM}[$saved_slug]${RESET}: "
  else
    echo -en "${BOLD}Foundry app slug${RESET} ${DIM}[optional, press enter to skip]${RESET}: "
  fi
  read -r input_slug
  if [ -n "$input_slug" ]; then
    FOUNDRY_APP_SLUG="$input_slug"
  else
    FOUNDRY_APP_SLUG="${saved_slug:-}"
  fi
}

detect_agents() {
  AGENTS=()
  if command -v claude &>/dev/null; then
    AGENTS+=("claude-code")
  fi
  if [ -d ".cursor" ] || command -v cursor &>/dev/null; then
    AGENTS+=("cursor")
  fi
  if [ ${#AGENTS[@]} -eq 0 ]; then
    AGENTS=("claude-code" "cursor")
  fi
}

