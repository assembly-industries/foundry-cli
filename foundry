# ─── Commands ──────────────────────────────────────────────────────────────────

cmd_init() {
  header "Foundry Init"
  echo -e "${DIM}Setting up Foundry agent integration in the current directory.${RESET}"
  echo ""

  # Collect token
  if [ -n "${FOUNDRY_TOKEN:-}" ]; then
    info "Using token from environment: FOUNDRY_TOKEN"
  else
    load_config
    if [ -n "${FOUNDRY_TOKEN:-}" ]; then
      info "Using token from ${DIM}$FOUNDRY_CONFIG_FILE${RESET}"
    else
      echo -en "${BOLD}Foundry service token: ${RESET}"
      read -r FOUNDRY_TOKEN
      if [ -z "$FOUNDRY_TOKEN" ]; then
        error "Token is required. Generate one from the admin UI → Agent Access tab."
        exit 1
      fi
    fi
  fi

  # Collect MCP URL
  if [ -z "${FOUNDRY_MCP_URL:-}" ]; then
    local default_url="http://localhost:8082/v0/mcp-tools/stream"
    echo -en "${BOLD}MCP server URL${RESET} ${DIM}[$default_url]${RESET}: "
    read -r FOUNDRY_MCP_URL
    FOUNDRY_MCP_URL="${FOUNDRY_MCP_URL:-$default_url}"
  fi

  # Collect app slug (optional)
  if [ -z "${FOUNDRY_APP_SLUG:-}" ]; then
    echo -en "${BOLD}Foundry app slug${RESET} ${DIM}[optional, press enter to skip]${RESET}: "
    read -r FOUNDRY_APP_SLUG
  fi

  echo ""
  detect_agents
  local agent_list
  agent_list=$(printf '%s, ' "${AGENTS[@]}")
  info "Detected agents: ${agent_list%, }"
  echo ""

  # ── Save config ──────────────────────────────────────────────────────────
  save_config

  # ── .gitignore guard ─────────────────────────────────────────────────────
  if [ -f ".gitignore" ]; then
    if ! grep -qxF '.foundry/' .gitignore 2>/dev/null; then
      echo '.foundry/' >> .gitignore
      success "Added ${DIM}.foundry/${RESET} to .gitignore"
    fi
  else
    echo '.foundry/' > .gitignore
    success "Created .gitignore with ${DIM}.foundry/${RESET}"
  fi

  # ── Claude Code setup ───────────────────────────────────────────────────
  header "Claude Code"

  local claude_mcp
  claude_mcp=$(cat <<JSON
{
  "mcpServers": {
    "assembly-foundry": {
      "type": "streamable-http",
      "url": "\${ASSEMBLY_MCP_URL:-$FOUNDRY_MCP_URL}",
      "headers": {
        "Authorization": "Bearer \${ASSEMBLY_FOUNDRY_TOKEN}"
      }
    }
  }
}
JSON
)
  write_file ".mcp.json" "$claude_mcp"
  success "Created: ${DIM}.mcp.json${RESET}"

  ensure_dir ".claude/skills/foundry"
  write_file ".claude/skills/foundry/SKILL.md" "$SKILL_CONTENT"
  success "Created: ${DIM}.claude/skills/foundry/SKILL.md${RESET}"

  # ── Cursor setup ─────────────────────────────────────────────────────────
  header "Cursor"

  local cursor_mcp
  cursor_mcp=$(cat <<JSON
{
  "mcpServers": {
    "assembly-foundry": {
      "url": "$FOUNDRY_MCP_URL",
      "headers": {
        "Authorization": "Bearer \${ASSEMBLY_FOUNDRY_TOKEN}"
      }
    }
  }
}
JSON
)
  ensure_dir ".cursor"
  write_file ".cursor/mcp.json" "$cursor_mcp"
  success "Created: ${DIM}.cursor/mcp.json${RESET}"

  ensure_dir ".cursor/rules"
  write_file ".cursor/rules/foundry-agent.mdc" "$CURSOR_RULE_CONTENT"
  success "Created: ${DIM}.cursor/rules/foundry-agent.mdc${RESET}"

  # ── Env var hint ─────────────────────────────────────────────────────────
  header "Almost done"
  echo ""
  echo -e "Set the token in your shell before launching an agent:"
  echo ""
  echo -e "  ${BOLD}export ASSEMBLY_FOUNDRY_TOKEN=\"$FOUNDRY_TOKEN\"${RESET}"
  echo ""
  echo -e "Or add it to your shell profile (~/.zshrc, ~/.bashrc)."

  if [ -n "${FOUNDRY_APP_SLUG:-}" ]; then
    echo ""
    echo -e "Start building from the PRD:"
    echo ""
    echo -e "  ${DIM}claude${RESET}"
    echo -e "  ${BOLD}> Pull the Foundry context for \"$FOUNDRY_APP_SLUG\" and start building.${RESET}"
  fi

  echo ""
  success "Foundry init complete."
}

cmd_status() {
  header "Foundry Status"
  load_config

  local ok=true

  if [ -f ".mcp.json" ]; then
    success ".mcp.json exists"
  else
    warn ".mcp.json missing — run ${BOLD}foundry init${RESET}"
    ok=false
  fi

  if [ -f ".claude/skills/foundry/SKILL.md" ]; then
    success ".claude/skills/foundry/SKILL.md exists"
  else
    warn ".claude/skills/foundry/SKILL.md missing"
    ok=false
  fi

  if [ -f ".cursor/mcp.json" ]; then
    success ".cursor/mcp.json exists"
  else
    warn ".cursor/mcp.json missing"
    ok=false
  fi

  if [ -f ".cursor/rules/foundry-agent.mdc" ]; then
    success ".cursor/rules/foundry-agent.mdc exists"
  else
    warn ".cursor/rules/foundry-agent.mdc missing"
    ok=false
  fi

  if [ -n "${ASSEMBLY_FOUNDRY_TOKEN:-}" ]; then
    success "ASSEMBLY_FOUNDRY_TOKEN is set"
  elif [ -n "${FOUNDRY_TOKEN:-}" ]; then
    success "Token found in ${DIM}$FOUNDRY_CONFIG_FILE${RESET}"
  else
    warn "No token — set ASSEMBLY_FOUNDRY_TOKEN or run ${BOLD}foundry init${RESET}"
    ok=false
  fi

  local mcp_url="${FOUNDRY_MCP_URL:-${ASSEMBLY_MCP_URL:-http://localhost:8082/v0/mcp-tools/stream}}"
  if curl -sf --max-time 3 "$mcp_url" >/dev/null 2>&1 || curl -sf --max-time 3 -o /dev/null -w '%{http_code}' "$mcp_url" 2>/dev/null | grep -q '[2-4]'; then
    success "MCP server reachable at ${DIM}$mcp_url${RESET}"
  else
    warn "MCP server not reachable at ${DIM}$mcp_url${RESET}"
    ok=false
  fi

  echo ""
  if [ "$ok" = true ]; then
    success "All checks passed. Ready to use Foundry."
  else
    warn "Some checks failed. Run ${BOLD}foundry init${RESET} to fix."
  fi
}

cmd_version() {
  echo "foundry $FOUNDRY_VERSION"
}

cmd_help() {
  echo -e "${BOLD}foundry${RESET} — CLI for Assembly Foundry agent integration"
  echo ""
  echo -e "${BOLD}USAGE${RESET}"
  echo "  foundry <command> [options]"
  echo ""
  echo -e "${BOLD}COMMANDS${RESET}"
  echo "  init      Set up Foundry in the current directory (MCP config, skills, rules)"
  echo "  status    Check if Foundry is correctly configured"
  echo "  version   Print version"
  echo "  help      Show this help"
  echo ""
  echo -e "${BOLD}EXAMPLES${RESET}"
  echo "  foundry init                         Interactive setup"
  echo "  FOUNDRY_TOKEN=sat_xxx foundry init   Non-interactive with token from env"
  echo "  foundry status                       Verify everything is configured"
  echo ""
  echo -e "${BOLD}ENVIRONMENT${RESET}"
  echo "  FOUNDRY_TOKEN       Service token (can also be set interactively)"
  echo "  FOUNDRY_MCP_URL     MCP server URL (default: http://localhost:8082/v0/mcp-tools/stream)"
  echo "  FOUNDRY_APP_SLUG    Default app slug for the project"
}

# ─── Entrypoint ────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)    cmd_init "$@" ;;
    status)  cmd_status "$@" ;;
    version) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)
      error "Unknown command: $cmd"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
